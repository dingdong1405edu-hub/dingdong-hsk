# Database
DATABASE_URL="postgresql://user:pass@host:5432/dingdong_hsk"

# Auth — Google is the ONLY sign-in method. Both values below are REQUIRED;
# without them nobody can log in. Create credentials at
# https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, type
# "Web application"). Authorized redirect URI:
#   https://<your-domain>/api/auth/callback/google
#
# !!! IF ONLY *SOME* GOOGLE ACCOUNTS CAN SIGN IN (e.g. the owner works but other
# people get "Access blocked / app is being tested"): the OAuth *consent screen*
# is still in "Testing" mode, which only allows whitelisted test users.
# FIX: Google Cloud Console → APIs & Services → OAuth consent screen →
# "PUBLISH APP" (move Testing → In production). Scopes used are only
# email/profile/openid (non-sensitive), so NO Google verification is required —
# it takes effect immediately for all Google accounts.
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# AI Grading + sinh câu hỏi + STT dự phòng + trợ lý chat (Groq - https://console.groq.com)
#  - Chấm viết/nói, AI tạo câu hỏi đọc/nghe.
#  - STT dự phòng (Whisper) cho /api/transcribe khi Deepgram lỗi/thiếu key.
#  - Trợ lý chat "Bao" (/api/chat) hỗ trợ người học — dùng chung key này.
GROQ_API_KEY=""

# (Tuỳ chọn) Ghi đè model cho trợ lý chat "Bao". Mặc định: llama-3.3-70b-versatile.
GROQ_CHAT_MODEL=""

# (Tuỳ chọn) Danh sách model chấm VIẾT LUẬN, ưu tiên trái→phải; model lỗi/JSON
# hỏng thì tự rớt sang model kế. Bỏ trống = mặc định Qwen (mạnh tiếng Trung) →
# gpt-oss-120b (Production) → llama. Ví dụ: "openai/gpt-oss-120b,qwen/qwen3.6-27b".
GROQ_WRITING_MODELS=""

# (Tuỳ chọn) Danh sách model cho các luồng JSON khác: chấm NÓI, sinh câu hỏi
# đọc/nghe, giải thích đáp án. Cùng quy tắc fallback trái→phải. Bỏ trống = mặc
# định Qwen → gpt-oss-120b → llama.
GROQ_GRADING_MODELS=""

# Speech-to-Text tiếng Trung (Deepgram Nova-3 - https://console.deepgram.com)
#  - Chấm nói (HSKK) trong /api/transcribe.
#  - Admin: "Tạo transcript từ audio" ở phần Bài nghe.
DEEPGRAM_API_KEY=""
# (Tùy chọn) Ghi đè model / ngôn ngữ Deepgram. Mặc định: nova-3 + zh-CN (Quan thoại
# giản thể). Dùng zh-TW cho phồn thể, zh-HK cho tiếng Quảng Đông.
DEEPGRAM_STT_MODEL=""
DEEPGRAM_STT_LANGUAGE=""

# Text-to-Speech tiếng Trung (Google Cloud Text-to-Speech)
#  - Admin: "Tạo MP3 từ transcript" ở phần Bài nghe (giọng Quan thoại cmn-CN).
#  - Tạo API key tại https://console.cloud.google.com/apis/credentials và BẬT
#    "Cloud Text-to-Speech API" cho project. (Deepgram & Groq KHÔNG có giọng TTS
#    tiếng Trung nên phần tạo audio dùng Google.)
GOOGLE_TTS_API_KEY=""
# (Tùy chọn) Ghi đè giọng / ngôn ngữ. Mặc định: cmn-CN + cmn-CN-Wavenet-A (nữ).
# Giọng nam: cmn-CN-Wavenet-B / cmn-CN-Wavenet-C.
GOOGLE_TTS_VOICE=""
GOOGLE_TTS_LANGUAGE=""

# Payment (PayOS - https://my.payos.vn → Kênh thanh toán → "Thông tin xác thực")
# Dán 3 giá trị lấy trong dashboard PayOS vào đây:
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
# Sau khi deploy, vào dashboard PayOS đặt Webhook URL thành:
#   https://<your-domain>/api/payos/webhook
# (Giá & tên gói cấu hình trong src/lib/payment-plans.ts — không phải biến môi trường.)

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
