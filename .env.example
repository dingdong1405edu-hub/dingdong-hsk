# Database
DATABASE_URL="postgresql://user:pass@host:5432/dingdong_hsk"

# Auth — Google is the ONLY sign-in method. Both values below are REQUIRED;
# without them nobody can log in. Create credentials at
# https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, type
# "Web application"). Authorized redirect URI:
#   https://<your-domain>/api/auth/callback/google
#
# !!! IF ONLY *SOME* GOOGLE ACCOUNTS CAN SIGN IN (e.g. the owner works but other
# people get "Access blocked / app is being tested"): the OAuth *consent screen*
# is still in "Testing" mode, which only allows whitelisted test users.
# FIX: Google Cloud Console → APIs & Services → OAuth consent screen →
# "PUBLISH APP" (move Testing → In production). Scopes used are only
# email/profile/openid (non-sensitive), so NO Google verification is required —
# it takes effect immediately for all Google accounts.
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# AI Grading (Groq - https://console.groq.com)
GROQ_API_KEY=""

# Speech-to-Text (Deepgram - https://console.deepgram.com)
DEEPGRAM_API_KEY=""

# Payment (PayOS - https://my.payos.vn → Kênh thanh toán → "Thông tin xác thực")
# Dán 3 giá trị lấy trong dashboard PayOS vào đây:
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
# Sau khi deploy, vào dashboard PayOS đặt Webhook URL thành:
#   https://<your-domain>/api/payos/webhook
# (Giá & tên gói cấu hình trong src/lib/payment-plans.ts — không phải biến môi trường.)

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
