generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  ADMIN
}

enum HSKLevel {
  HSK1
  HSK2
  HSK3
  HSK4
  HSK5
  HSK6
}

enum Skill {
  READING
  LISTENING
  WRITING
  SPEAKING
  VOCAB
  GRAMMAR
  HANZI
  MOCK // bài thi thử trọn bộ (MockExam) — dùng cho Attempt.skill
}

enum QuestionType {
  MCQ
  FILL_BLANK
  TRUE_FALSE
  MATCHING
  SHORT_ANSWER
}

enum WritingTaskType {
  FREE
  GUIDED
  PICTURE_DESCRIPTION
}

enum MaterialCategory {
  GRAMMAR
  VOCABULARY
  HANZI
  PRONUNCIATION
  EXAM_TIPS
  CULTURE
  CONVERSATION
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  image           String?
  emailVerified   DateTime?
  passwordHash    String?
  role            Role      @default(LEARNER)
  xp              Int       @default(0)
  hearts          Int       @default(5)
  heartsUpdatedAt DateTime? // mốc tính hồi tim (regen) — null = đang đầy
  streakDays      Int       @default(0)
  hskLevel        HSKLevel  @default(HSK1)
  lastActiveAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  banned          Boolean   @default(false)

  accounts        Account[]
  sessions        Session[]
  vocabProgress   VocabProgress[]
  vocabReviews    VocabReview[]
  grammarProgress GrammarProgress[]
  hanziProgress   HanziProgress[]
  roadmapProgress RoadmapProgress[]
  attempts        Attempt[]
  payments        Payment[]
  subscriptions   Subscription[]
  wordReports     WordReport[]
  savedWords      SavedWord[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VocabUnit {
  id        String        @id @default(cuid())
  title     String
  titleZh   String
  hskLevel  HSKLevel
  order     Int
  imageUrl  String?
  published Boolean       @default(true) // false = bản nháp (ẩn khỏi web học viên)
  lessons   VocabLesson[]

  @@index([hskLevel, order])
}

model VocabLesson {
  id        String    @id @default(cuid())
  unitId    String
  unit      VocabUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String    @default("")
  exercises Json
  published Boolean   @default(true) // false = bản nháp (ẩn khỏi web học viên)

  progress VocabProgress[]
  words    VocabWord[]

  @@index([unitId, order])
}

/// A single vocabulary word taught in the per-word learner flow
/// (show + auto-read → trace strokes → write → flashcards). Authored from the
/// admin word editor. Stroke data is NOT stored here — Hanzi Writer loads it from
/// CDN by character. `examples` is a JSON array of { hanzi, pinyin, meaning }.
model VocabWord {
  id        String      @id @default(cuid())
  lessonId  String
  lesson    VocabLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int
  hanzi     String
  pinyin    String
  meaning   String
  examples  Json        @default("[]")
  audioUrl  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt

  reviews VocabReview[]
  reports WordReport[]

  @@index([lessonId, order])
}

model VocabProgress {
  id            String   @id @default(cuid())
  userId        String
  lessonId      String
  completed     Boolean  @default(false)
  xpEarned      Int      @default(0)
  // Vị trí đang học dở (cho nút "Học tiếp" — resume). lastWordIndex = chỉ số từ
  // hiện tại trong bài, lastStep = bước trong từ đó (0 xem thẻ · 1 tô nét · 2 tự
  // viết). Reset về 0 khi hoàn thành để lần vào sau là "Học lại" từ đầu.
  lastWordIndex Int      @default(0)
  lastStep      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson VocabLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

/// Trạng thái lặp lại ngắt quãng (spaced repetition · SM-2) cho từng từ vựng của
/// mỗi người học — dùng cho chế độ "Ôn từ". `dueAt` = thời điểm đến hạn ôn kế
/// tiếp; `ease` (easiness factor) ≥ 1.3; `intervalDays` = khoảng cách hiện tại.
/// Thuật toán cập nhật ở src/lib/srs.ts.
model VocabReview {
  id             String    @id @default(cuid())
  userId         String
  wordId         String
  repetitions    Int       @default(0) // số lần trả lời đúng liên tiếp
  intervalDays   Int       @default(0) // khoảng cách hiện tại (ngày)
  ease           Float     @default(2.5) // hệ số dễ (easiness factor)
  lapses         Int       @default(0) // số lần quên (trả lời sai)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, dueAt])
}

model GrammarUnit {
  id        String          @id @default(cuid())
  title     String
  titleZh   String
  hskLevel  HSKLevel
  order     Int
  imageUrl  String?
  published Boolean         @default(true) // false = bản nháp (ẩn khỏi web học viên)
  lessons   GrammarLesson[]

  @@index([hskLevel, order])
}

model GrammarLesson {
  id        String      @id @default(cuid())
  unitId    String
  unit      GrammarUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String      @default("")
  exercises Json
  published Boolean     @default(true) // false = bản nháp (ẩn khỏi web học viên)

  progress GrammarProgress[]

  @@index([unitId, order])
}

model GrammarProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model HanziCharacter {
  id          String   @id @default(cuid())
  character   String   @unique
  pinyin      String
  tone        Int
  meaning     String
  hskLevel    HSKLevel
  strokeCount Int
  strokeOrder Json
  examples    Json
  imageUrl    String?
  order       Int      @default(0) // thứ tự hiển thị trong cấp HSK (đổi chỗ ở admin)
  published   Boolean  @default(true) // false = bản nháp (ẩn khỏi web học viên)

  progress HanziProgress[]

  @@index([hskLevel, order])
}

model HanziProgress {
  id          String   @id @default(cuid())
  userId      String
  characterId String
  mastered    Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  character HanziCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model ReadingTest {
  id            String   @id @default(cuid())
  title         String
  titleZh       String
  hskLevel      HSKLevel
  passage       String   @db.Text
  passagePinyin String?  @db.Text
  imageUrl      String?
  timeLimit     Int
  order         Int      @default(0) // thứ tự hiển thị trong cấp HSK (đổi chỗ ở admin)
  published     Boolean  @default(true) // false = bản nháp (ẩn khỏi web học viên)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  questions Question[]

  @@index([hskLevel, order])
}

model ListeningTest {
  id         String   @id @default(cuid())
  title      String
  hskLevel   HSKLevel
  audioUrl   String
  transcript String?  @db.Text
  imageUrl   String?
  timeLimit  Int      @default(300)
  order      Int      @default(0) // thứ tự hiển thị trong cấp HSK (đổi chỗ ở admin)
  published  Boolean  @default(true) // false = bản nháp (ẩn khỏi web học viên)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  questions Question[]

  @@index([hskLevel, order])
}

model Question {
  id              String       @id @default(cuid())
  type            QuestionType
  prompt          String       @db.Text
  promptPinyin    String?      @db.Text
  options         Json?
  correctAnswer   Json
  explanation     String?      @db.Text
  // Câu/đoạn trích trong bài đọc chứng minh đáp án (Groq sinh sẵn khi admin thêm
  // câu hỏi) — dùng để "chỉ cho học viên đáp án lấy ở đâu" khi chữa bài.
  supportingQuote String?      @db.Text
  order           Int          @default(0)

  readingId   String?
  listeningId String?
  examPartId  String?

  reading   ReadingTest?   @relation(fields: [readingId], references: [id], onDelete: Cascade)
  listening ListeningTest? @relation(fields: [listeningId], references: [id], onDelete: Cascade)
  examPart  MockExamPart?  @relation(fields: [examPartId], references: [id], onDelete: Cascade)

  @@index([examPartId, order])
}

// ===================================================================
//  THI THỬ (Mock exam) — đề HSK trọn bộ, đúng format máy thật.
//  MockExam (1 đề/cấp) → MockExamSection (Nghe/Đọc/Viết) →
//  MockExamPart (第一部分...) → Question (dùng lại model Question).
//  Một tiểu phần là DANH SÁCH câu hỏi auto-chấm (Nghe/Đọc, và 连词成句/
//  看拼音写汉字 của Viết dùng FILL_BLANK), HOẶC một ô viết tự luận
//  (writingPrompt ≠ null) chấm bằng AI. Bài thi lưu 1 Attempt (skill = MOCK).
// ===================================================================

model MockExam {
  id          String   @id @default(cuid())
  title       String // "Đề thi thử HSK4 — Đề 1"
  titleZh     String?
  hskLevel    HSKLevel
  description String?  @db.Text
  totalTime   Int? // tổng thời gian (giây); null = cộng dồn từ các phần
  order       Int      @default(0) // thứ tự hiển thị trong cấp HSK
  published   Boolean  @default(false) // false = bản nháp (ẩn khỏi web học viên)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  sections MockExamSection[]

  @@index([hskLevel, order])
}

model MockExamSection {
  id           String   @id @default(cuid())
  examId       String
  exam         MockExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  skill        Skill // LISTENING | READING | WRITING
  order        Int      @default(0)
  title        String   @default("") // "一、听力" (suy từ skill nếu trống)
  instructions String?  @db.Text

  parts MockExamPart[]

  @@index([examId, order])
}

model MockExamPart {
  id              String          @id @default(cuid())
  sectionId       String
  section         MockExamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  order           Int             @default(0)
  title           String          @default("") // "第一部分"
  instructions    String?         @db.Text // hướng dẫn / ví dụ 例如
  imageUrl        String? // ảnh dùng chung cho tiểu phần (câu hỏi nhìn hình)
  // Đọc hiểu:
  passage         String?         @db.Text
  passagePinyin   String?         @db.Text
  // Nghe hiểu:
  audioUrl        String?
  transcript      String?         @db.Text
  // Viết tự luận (HSK5/6): nếu set => tiểu phần là 1 ô viết, chấm bằng AI
  writingPrompt   String?         @db.Text
  writingMinChars Int?

  questions Question[]

  @@index([sectionId, order])
}

model WritingTask {
  id        String          @id @default(cuid())
  taskType  WritingTaskType
  prompt    String          @db.Text
  promptZh  String?         @db.Text
  // Dàn ý gợi ý (admin nhập, mỗi ý một dòng) — ẩn mặc định, học viên bấm "Gợi ý
  // dàn ý" mới hiện. Cũng được đưa vào prompt chấm AI để kiểm tra bám sát dàn ý.
  outline   String?         @db.Text
  imageUrl  String?
  minChars  Int
  timeLimit Int
  hskLevel  HSKLevel
  order     Int             @default(0) // thứ tự hiển thị trong cấp HSK (đổi chỗ ở admin)
  published Boolean         @default(true) // false = bản nháp (ẩn khỏi web học viên)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([hskLevel, order])
}

model SpeakingSet {
  id             String   @id @default(cuid())
  title          String   @default("")
  hskLevel       HSKLevel
  imageUrl       String?
  part1Sentences Json
  part2Passage   Json
  part3Questions Json
  order          Int      @default(0) // thứ tự hiển thị trong cấp HSK (đổi chỗ ở admin)
  published      Boolean  @default(true) // false = bản nháp (ẩn khỏi web học viên)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([hskLevel, order])
}

/// Tài liệu học tập (study materials / documents). Content is stored as an
/// array of structured blocks (see prisma/seed.ts and the learner renderer):
///   heading | paragraph | list | example | vocab | note
model Material {
  id          String           @id @default(cuid())
  title       String
  titleZh     String?
  category    MaterialCategory
  hskLevel    HSKLevel
  summary     String           @db.Text
  imageUrl    String?
  content     Json
  tags        Json?
  readMinutes Int              @default(5)
  order       Int              @default(0)
  published   Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  @@index([hskLevel, category, order])
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  skill       Skill
  refId       String
  rawAnswer   Json
  score       Float?
  feedback    Json?
  durationSec Int?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, skill])
  @@index([userId, createdAt])
}

// ===================================================================
//  HỌC THEO LỘ TRÌNH (Learning roadmap — Duolingo-style)
//  Course (1 per HSK level) → RoadmapLesson (10–20 / course) →
//  RoadmapSection (6 kỹ năng: từ vựng, ngữ pháp, nghe, nói, đọc, viết).
//  Nội dung từng kỹ năng được điền sau (RoadmapSection.content / refId);
//  tiến độ học theo dõi trong RoadmapProgress.
// ===================================================================

/// Một khóa học = một cấp HSK. Mỗi cấp có một khóa duy nhất.
model Course {
  id          String   @id @default(cuid())
  hskLevel    HSKLevel @unique
  title       String
  titleZh     String
  description String?  @db.Text
  order       Int
  imageUrl    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  lessons RoadmapLesson[]

  @@index([order])
}

/// Một bài trong lộ trình: một chủ đề, gom đủ 6 kỹ năng.
/// `chapter` / `chapterOrder` gom các bài thành chương (banner trên map).
model RoadmapLesson {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order        Int
  topic        String
  topicZh      String
  description  String?  @db.Text
  icon         String?
  chapter      String?
  chapterOrder Int      @default(1)
  xpReward     Int      @default(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  sections RoadmapSection[]
  progress RoadmapProgress[]

  @@unique([courseId, order])
  @@index([courseId, chapterOrder, order])
}

/// Một kỹ năng trong bài (VOCAB | GRAMMAR | LISTENING | SPEAKING | READING | WRITING).
/// `published = false` => "Sắp có". `content` (JSON) hoặc `refId` (trỏ tới nội dung
/// có sẵn: VocabLesson / ReadingTest / ...) được điền sau.
model RoadmapSection {
  id        String        @id @default(cuid())
  lessonId  String
  lesson    RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  skill     Skill
  order     Int           @default(0)
  title     String        @default("")
  content   Json?
  refId     String?
  published Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt

  @@unique([lessonId, skill])
  @@index([lessonId, order])
}

/// Tiến độ của người học theo từng bài lộ trình.
/// `skillsDone` = mảng tên Skill đã hoàn thành (để mở khoá dần / tính %).
model RoadmapProgress {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean       @default(false)
  skillsDone  Json          @default("[]")
  score       Float?
  xpEarned    Int           @default(0)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
  FAILED
}

/// Đơn thanh toán qua PayOS. Ghi nhận giao dịch (không khoá tính năng).
/// `orderCode` là mã đơn gửi cho PayOS (số nguyên duy nhất) — dùng BigInt vì
/// được sinh từ timestamp (vượt phạm vi Int 32-bit). `rawWebhook` lưu nguyên
/// payload webhook để đối soát. Giá/tên gói cấu hình ở src/lib/payment-plans.ts.
model Payment {
  id            String        @id @default(cuid())
  orderCode     BigInt        @unique
  userId        String?
  amount        Int
  description   String
  planId        String?
  planName      String
  status        PaymentStatus @default(PENDING)
  buyerName     String?
  buyerEmail    String?
  checkoutUrl   String?       @db.Text
  paymentLinkId String?
  reference     String?
  paidAt        DateTime?
  rawWebhook    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

enum SubscriptionType {
  FREESTYLE // Gói tự do: mọi tính năng ngoài lộ trình + tim không giới hạn
  ROADMAP // Gói lộ trình theo cấp HSK (hskLevel)
}

/// Quyền lợi đã mua của người học. Một lần mua có thể tạo nhiều Subscription
/// (vd gói Lộ trình HSK3–6 tặng kèm 1 Subscription FREESTYLE). Quyền được tính
/// là CÒN HẠN khi expiresAt > now. Cấu hình gói (giá/thời hạn/quyền) ở
/// src/lib/payment-plans.ts; cách suy ra quyền ở src/lib/entitlements.ts.
model Subscription {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      SubscriptionType
  hskLevel  HSKLevel? // chỉ dùng cho ROADMAP
  startedAt DateTime         @default(now())
  expiresAt DateTime
  paymentId String? // Payment.id đã kích hoạt quyền này (idempotent)
  createdAt DateTime         @default(now())

  @@index([userId, expiresAt])
  @@index([paymentId])
}

enum WordReportKind {
  ERROR // Báo lỗi: từ/nghĩa/pinyin bị sai
  COMMENT // Bình luận / góp ý
}

enum WordReportStatus {
  PENDING // Chờ admin duyệt — chỉ chủ bài thấy
  APPROVED // Đã duyệt — hiển thị công khai cho mọi học viên
  REJECTED // Bị từ chối — ẩn
}

/// Phản ánh / bình luận của học viên trên một từ vựng. Admin nhận ở
/// /admin/word-reports; chỉ khi `status = APPROVED` thì bình luận mới hiển thị
/// công khai cho các học viên khác (kiểm duyệt). Báo lỗi (ERROR) chủ yếu để admin
/// sửa nội dung từ; bình luận (COMMENT) sau khi duyệt sẽ hiện dưới thẻ từ.
model WordReport {
  id        String           @id @default(cuid())
  userId    String
  wordId    String
  kind      WordReportKind   @default(COMMENT)
  content   String           @db.Text
  status    WordReportStatus @default(PENDING)
  adminNote String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @default(now()) @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId, status])
  @@index([status, createdAt])
}

/// "Sổ từ" — từ học viên lưu lại khi tra cứu (đọc hiểu, v.v.). Chỉ lưu các từ có
/// trong từ điển (HanziCharacter). Snapshot pinyin/nghĩa tại thời điểm lưu để giữ
/// nguyên kể cả khi từ điển thay đổi. Một học viên mỗi từ (hanzi) chỉ lưu 1 lần.
model SavedWord {
  id        String   @id @default(cuid())
  userId    String
  hanzi     String // chữ Hán đã lưu (1 ký tự hoặc cụm)
  pinyin    String
  meaning   String   @db.Text
  hskLevel  String?
  source    String? // ngữ cảnh: "reading:<id>" / "listening:<id>" ...
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hanzi])
  @@index([userId, createdAt])
}

/// Tệp do admin tải lên / sinh ra (ảnh minh hoạ, audio bài nghe, MP3 từ TTS).
/// Lưu THẲNG trong Postgres (cột `data` Bytes) thay vì ghi vào public/ — vì
/// filesystem trên Railway là EPHEMERAL nên file trong public/ bị xoá sau mỗi
/// lần deploy/restart (đó là lý do "tải lên nhưng không lưu được"). Phục vụ qua
/// `/api/files/[id]` với Content-Type = `mime`. URL lưu ở imageUrl/audioUrl là
/// `/api/files/<id>`.
model Upload {
  id        String   @id @default(cuid())
  mime      String // VD: "image/webp", "audio/mpeg"
  ext       String // đuôi chuẩn hoá: png/jpg/webp/mp3/wav/...
  size      Int // số byte (dùng cho Content-Length)
  kind      String   @default("image") // "image" | "audio" (chỉ để phân loại)
  data      Bytes // nội dung tệp (Postgres bytea)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
