generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  ADMIN
}

enum HSKLevel {
  HSK1
  HSK2
  HSK3
  HSK4
  HSK5
  HSK6
}

enum Skill {
  READING
  LISTENING
  WRITING
  SPEAKING
  VOCAB
  GRAMMAR
  HANZI
}

enum QuestionType {
  MCQ
  FILL_BLANK
  TRUE_FALSE
  MATCHING
  SHORT_ANSWER
}

enum WritingTaskType {
  FREE
  GUIDED
  PICTURE_DESCRIPTION
}

enum MaterialCategory {
  GRAMMAR
  VOCABULARY
  HANZI
  PRONUNCIATION
  EXAM_TIPS
  CULTURE
  CONVERSATION
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(LEARNER)
  xp            Int       @default(0)
  hearts        Int       @default(5)
  streakDays    Int       @default(0)
  hskLevel      HSKLevel  @default(HSK1)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())
  banned        Boolean   @default(false)

  accounts         Account[]
  sessions         Session[]
  vocabProgress    VocabProgress[]
  grammarProgress  GrammarProgress[]
  hanziProgress    HanziProgress[]
  attempts         Attempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VocabUnit {
  id       String      @id @default(cuid())
  title    String
  titleZh  String
  hskLevel HSKLevel
  order    Int
  imageUrl String?
  lessons  VocabLesson[]

  @@index([hskLevel, order])
}

model VocabLesson {
  id        String    @id @default(cuid())
  unitId    String
  unit      VocabUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String    @default("")
  exercises Json

  progress  VocabProgress[]

  @@index([unitId, order])
}

model VocabProgress {
  id        String      @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean     @default(false)
  xpEarned  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson VocabLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model GrammarUnit {
  id       String          @id @default(cuid())
  title    String
  titleZh  String
  hskLevel HSKLevel
  order    Int
  imageUrl String?
  lessons  GrammarLesson[]

  @@index([hskLevel, order])
}

model GrammarLesson {
  id        String      @id @default(cuid())
  unitId    String
  unit      GrammarUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String      @default("")
  exercises Json

  progress  GrammarProgress[]

  @@index([unitId, order])
}

model GrammarProgress {
  id        String        @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean       @default(false)
  xpEarned  Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model HanziCharacter {
  id          String  @id @default(cuid())
  character   String  @unique
  pinyin      String
  tone        Int
  meaning     String
  hskLevel    HSKLevel
  strokeCount Int
  strokeOrder Json
  examples    Json
  imageUrl    String?

  progress HanziProgress[]
}

model HanziProgress {
  id          String         @id @default(cuid())
  userId      String
  characterId String
  mastered    Boolean        @default(false)
  attempts    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  character HanziCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model ReadingTest {
  id            String   @id @default(cuid())
  title         String
  titleZh       String
  hskLevel      HSKLevel
  passage       String   @db.Text
  passagePinyin String?  @db.Text
  imageUrl      String?
  timeLimit     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  questions Question[]
}

model ListeningTest {
  id         String   @id @default(cuid())
  title      String
  hskLevel   HSKLevel
  audioUrl   String
  transcript String?  @db.Text
  imageUrl   String?
  timeLimit  Int      @default(300)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  questions Question[]
}

model Question {
  id           String       @id @default(cuid())
  type         QuestionType
  prompt       String       @db.Text
  promptPinyin String?      @db.Text
  options      Json?
  correctAnswer Json
  explanation  String?      @db.Text
  order        Int          @default(0)

  readingId   String?
  listeningId String?

  reading   ReadingTest?   @relation(fields: [readingId], references: [id], onDelete: Cascade)
  listening ListeningTest? @relation(fields: [listeningId], references: [id], onDelete: Cascade)
}

model WritingTask {
  id        String          @id @default(cuid())
  taskType  WritingTaskType
  prompt    String          @db.Text
  promptZh  String?         @db.Text
  imageUrl  String?
  minChars  Int
  timeLimit Int
  hskLevel  HSKLevel
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt @default(now())
}

model SpeakingSet {
  id             String   @id @default(cuid())
  title          String   @default("")
  hskLevel       HSKLevel
  imageUrl       String?
  part1Sentences Json
  part2Passage   Json
  part3Questions Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())
}

/// Tài liệu học tập (study materials / documents). Content is stored as an
/// array of structured blocks (see prisma/seed.ts and the learner renderer):
///   heading | paragraph | list | example | vocab | note
model Material {
  id          String           @id @default(cuid())
  title       String
  titleZh     String?
  category    MaterialCategory
  hskLevel    HSKLevel
  summary     String           @db.Text
  imageUrl    String?
  content     Json
  tags        Json?
  readMinutes Int              @default(5)
  order       Int              @default(0)
  published   Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt @default(now())

  @@index([hskLevel, category, order])
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  skill       Skill
  refId       String
  rawAnswer   Json
  score       Float?
  feedback    Json?
  durationSec Int?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, skill])
  @@index([userId, createdAt])
}
