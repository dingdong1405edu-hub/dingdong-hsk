generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  ADMIN
}

enum HSKLevel {
  HSK1
  HSK2
  HSK3
  HSK4
  HSK5
  HSK6
}

enum Skill {
  READING
  LISTENING
  WRITING
  SPEAKING
  VOCAB
  GRAMMAR
  HANZI
}

enum QuestionType {
  MCQ
  FILL_BLANK
  TRUE_FALSE
  MATCHING
  SHORT_ANSWER
}

enum WritingTaskType {
  FREE
  GUIDED
  PICTURE_DESCRIPTION
}

enum MaterialCategory {
  GRAMMAR
  VOCABULARY
  HANZI
  PRONUNCIATION
  EXAM_TIPS
  CULTURE
  CONVERSATION
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(LEARNER)
  xp            Int       @default(0)
  hearts        Int       @default(5)
  heartsUpdatedAt DateTime?            // mốc tính hồi tim (regen) — null = đang đầy
  streakDays    Int       @default(0)
  hskLevel      HSKLevel  @default(HSK1)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())
  banned        Boolean   @default(false)

  accounts         Account[]
  sessions         Session[]
  vocabProgress    VocabProgress[]
  grammarProgress  GrammarProgress[]
  hanziProgress    HanziProgress[]
  roadmapProgress  RoadmapProgress[]
  attempts         Attempt[]
  payments         Payment[]
  subscriptions    Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VocabUnit {
  id       String      @id @default(cuid())
  title    String
  titleZh  String
  hskLevel HSKLevel
  order    Int
  imageUrl String?
  lessons  VocabLesson[]

  @@index([hskLevel, order])
}

model VocabLesson {
  id        String    @id @default(cuid())
  unitId    String
  unit      VocabUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String    @default("")
  exercises Json

  progress  VocabProgress[]
  words     VocabWord[]

  @@index([unitId, order])
}

/// A single vocabulary word taught in the per-word learner flow
/// (show + auto-read → trace strokes → write → flashcards). Authored from the
/// admin word editor. Stroke data is NOT stored here — Hanzi Writer loads it from
/// CDN by character. `examples` is a JSON array of { hanzi, pinyin, meaning }.
model VocabWord {
  id        String      @id @default(cuid())
  lessonId  String
  lesson    VocabLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int
  hanzi     String
  pinyin    String
  meaning   String
  examples  Json        @default("[]")
  audioUrl  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt @default(now())

  @@index([lessonId, order])
}

model VocabProgress {
  id        String      @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean     @default(false)
  xpEarned  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson VocabLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model GrammarUnit {
  id       String          @id @default(cuid())
  title    String
  titleZh  String
  hskLevel HSKLevel
  order    Int
  imageUrl String?
  lessons  GrammarLesson[]

  @@index([hskLevel, order])
}

model GrammarLesson {
  id        String      @id @default(cuid())
  unitId    String
  unit      GrammarUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int
  title     String      @default("")
  exercises Json

  progress  GrammarProgress[]

  @@index([unitId, order])
}

model GrammarProgress {
  id        String        @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean       @default(false)
  xpEarned  Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson GrammarLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model HanziCharacter {
  id          String  @id @default(cuid())
  character   String  @unique
  pinyin      String
  tone        Int
  meaning     String
  hskLevel    HSKLevel
  strokeCount Int
  strokeOrder Json
  examples    Json
  imageUrl    String?

  progress HanziProgress[]
}

model HanziProgress {
  id          String         @id @default(cuid())
  userId      String
  characterId String
  mastered    Boolean        @default(false)
  attempts    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  character HanziCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model ReadingTest {
  id            String   @id @default(cuid())
  title         String
  titleZh       String
  hskLevel      HSKLevel
  passage       String   @db.Text
  passagePinyin String?  @db.Text
  imageUrl      String?
  timeLimit     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  questions Question[]
}

model ListeningTest {
  id         String   @id @default(cuid())
  title      String
  hskLevel   HSKLevel
  audioUrl   String
  transcript String?  @db.Text
  imageUrl   String?
  timeLimit  Int      @default(300)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  questions Question[]
}

model Question {
  id           String       @id @default(cuid())
  type         QuestionType
  prompt       String       @db.Text
  promptPinyin String?      @db.Text
  options      Json?
  correctAnswer Json
  explanation  String?      @db.Text
  order        Int          @default(0)

  readingId   String?
  listeningId String?

  reading   ReadingTest?   @relation(fields: [readingId], references: [id], onDelete: Cascade)
  listening ListeningTest? @relation(fields: [listeningId], references: [id], onDelete: Cascade)
}

model WritingTask {
  id        String          @id @default(cuid())
  taskType  WritingTaskType
  prompt    String          @db.Text
  promptZh  String?         @db.Text
  imageUrl  String?
  minChars  Int
  timeLimit Int
  hskLevel  HSKLevel
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt @default(now())
}

model SpeakingSet {
  id             String   @id @default(cuid())
  title          String   @default("")
  hskLevel       HSKLevel
  imageUrl       String?
  part1Sentences Json
  part2Passage   Json
  part3Questions Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())
}

/// Tài liệu học tập (study materials / documents). Content is stored as an
/// array of structured blocks (see prisma/seed.ts and the learner renderer):
///   heading | paragraph | list | example | vocab | note
model Material {
  id          String           @id @default(cuid())
  title       String
  titleZh     String?
  category    MaterialCategory
  hskLevel    HSKLevel
  summary     String           @db.Text
  imageUrl    String?
  content     Json
  tags        Json?
  readMinutes Int              @default(5)
  order       Int              @default(0)
  published   Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt @default(now())

  @@index([hskLevel, category, order])
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  skill       Skill
  refId       String
  rawAnswer   Json
  score       Float?
  feedback    Json?
  durationSec Int?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, skill])
  @@index([userId, createdAt])
}

// ===================================================================
//  HỌC THEO LỘ TRÌNH (Learning roadmap — Duolingo-style)
//  Course (1 per HSK level) → RoadmapLesson (10–20 / course) →
//  RoadmapSection (6 kỹ năng: từ vựng, ngữ pháp, nghe, nói, đọc, viết).
//  Nội dung từng kỹ năng được điền sau (RoadmapSection.content / refId);
//  tiến độ học theo dõi trong RoadmapProgress.
// ===================================================================

/// Một khóa học = một cấp HSK. Mỗi cấp có một khóa duy nhất.
model Course {
  id          String   @id @default(cuid())
  hskLevel    HSKLevel @unique
  title       String
  titleZh     String
  description String?  @db.Text
  order       Int
  imageUrl    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  lessons RoadmapLesson[]

  @@index([order])
}

/// Một bài trong lộ trình: một chủ đề, gom đủ 6 kỹ năng.
/// `chapter` / `chapterOrder` gom các bài thành chương (banner trên map).
model RoadmapLesson {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order        Int
  topic        String
  topicZh      String
  description  String?  @db.Text
  icon         String?
  chapter      String?
  chapterOrder Int      @default(1)
  xpReward     Int      @default(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())

  sections RoadmapSection[]
  progress RoadmapProgress[]

  @@unique([courseId, order])
  @@index([courseId, chapterOrder, order])
}

/// Một kỹ năng trong bài (VOCAB | GRAMMAR | LISTENING | SPEAKING | READING | WRITING).
/// `published = false` => "Sắp có". `content` (JSON) hoặc `refId` (trỏ tới nội dung
/// có sẵn: VocabLesson / ReadingTest / ...) được điền sau.
model RoadmapSection {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  skill     Skill
  order     Int      @default(0)
  title     String   @default("")
  content   Json?
  refId     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@unique([lessonId, skill])
  @@index([lessonId, order])
}

/// Tiến độ của người học theo từng bài lộ trình.
/// `skillsDone` = mảng tên Skill đã hoàn thành (để mở khoá dần / tính %).
model RoadmapProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      RoadmapLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  skillsDone  Json      @default("[]")
  score       Float?
  xpEarned    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
  FAILED
}

/// Đơn thanh toán qua PayOS. Ghi nhận giao dịch (không khoá tính năng).
/// `orderCode` là mã đơn gửi cho PayOS (số nguyên duy nhất) — dùng BigInt vì
/// được sinh từ timestamp (vượt phạm vi Int 32-bit). `rawWebhook` lưu nguyên
/// payload webhook để đối soát. Giá/tên gói cấu hình ở src/lib/payment-plans.ts.
model Payment {
  id            String        @id @default(cuid())
  orderCode     BigInt        @unique
  userId        String?
  amount        Int
  description   String
  planId        String?
  planName      String
  status        PaymentStatus @default(PENDING)
  buyerName     String?
  buyerEmail    String?
  checkoutUrl   String?       @db.Text
  paymentLinkId String?
  reference     String?
  paidAt        DateTime?
  rawWebhook    Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

enum SubscriptionType {
  FREESTYLE // Gói tự do: mọi tính năng ngoài lộ trình + tim không giới hạn
  ROADMAP   // Gói lộ trình theo cấp HSK (hskLevel)
}

/// Quyền lợi đã mua của người học. Một lần mua có thể tạo nhiều Subscription
/// (vd gói Lộ trình HSK3–6 tặng kèm 1 Subscription FREESTYLE). Quyền được tính
/// là CÒN HẠN khi expiresAt > now. Cấu hình gói (giá/thời hạn/quyền) ở
/// src/lib/payment-plans.ts; cách suy ra quyền ở src/lib/entitlements.ts.
model Subscription {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      SubscriptionType
  hskLevel  HSKLevel?        // chỉ dùng cho ROADMAP
  startedAt DateTime         @default(now())
  expiresAt DateTime
  paymentId String?          // Payment.id đã kích hoạt quyền này (idempotent)
  createdAt DateTime         @default(now())

  @@index([userId, expiresAt])
  @@index([paymentId])
}
