                ]
              }
            ],
            "test": {
              "timeLimit": 180,
              "passThreshold": 60,
              "questions": [
                {
                  "type": "fill_blank",
                  "sentence": "他___三本书。",
                  "blank": "有",
                  "options": ["有", "是", "看", "买"]
                },
                {
                  "type": "sentence_order",
                  "words": ["有", "我", "一个", "哥哥"],
                  "answer": "我有一个哥哥"
                },
                {
                  "type": "translate",
                  "direction": "vi_to_zh",
                  "prompt": "Tôi có một con mèo.",
                  "answer": "我有一只猫。",
                  "options": ["我有一只猫。", "我有一只狗。", "他有一只猫。", "我是一只猫。"]
                }
              ]
            }
          }
        },
