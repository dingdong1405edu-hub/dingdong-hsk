        {
          "id": "gr-HSK1-u1-l1",
          "title": "Động từ 是 (shì) - là",
          "order": 1,
          "exercises": {
            "version": 3,
            "sections": [
              {
                "id": "u1l1-shi",
                "title": "Câu khẳng định với 是",
                "titleZh": "“是”字句",
                "structure": "A + 是 + B",
                "explanation": "是 (shì) nghĩa là 'là', dùng để nối chủ ngữ (A) với một danh từ (B) nhằm khẳng định A chính là B. Đây là động từ liên kết quan trọng nhất trong tiếng Trung.",
                "examples": [
                  {
                    "situation": "Khi giới thiệu bản thân",
                    "hanzi": "我是学生。",
                    "pinyin": "wǒ shì xuésheng",
                    "meaning": "Tôi là học sinh."
                  },
                  {
                    "situation": "Khi nói về nghề nghiệp của người khác",
                    "hanzi": "他是老师。",
                    "pinyin": "tā shì lǎoshī",
                    "meaning": "Anh ấy là giáo viên."
                  }
                ],
                "exercises": [
                  {
                    "type": "fill_blank",
                    "sentence": "我___学生。",
                    "blank": "是",
                    "options": ["是", "有", "在", "叫"],
                    "hint": "Động từ 'là' nối chủ ngữ với danh từ."
                  },
                  {
                    "type": "sentence_order",
                    "words": ["老师", "是", "他"],
                    "answer": "他是老师",
                    "meaning": "Anh ấy là giáo viên."
                  },
                  {
                    "type": "answer_question",
                    "question": "你是学生吗？",
                    "questionPinyin": "nǐ shì xuésheng ma?",
                    "accept": ["我是学生", "是的，我是学生", "是"],
                    "sampleAnswer": "我是学生。",
                    "hint": "Trả lời khẳng định bằng 是."
                  }
                ]
              },
              {
                "id": "u1l1-note",
                "title": "Lưu ý: 是 đi với danh từ",
                "structure": "A + 是 + danh từ  (KHÔNG dùng với tính từ)",
                "explanation": "是 chỉ nối với danh từ, không dùng trước tính từ. Để nói 'rất vui' ta dùng 很 chứ không dùng 是. Sai phổ biến: ❌ 我是高兴 → ✔ 我很高兴.",
                "examples": [
                  {
                    "situation": "Phân biệt với tính từ",
                    "hanzi": "这是书。",
                    "pinyin": "zhè shì shū",
                    "meaning": "Đây là sách.",
                    "note": "是 đứng trước danh từ 书 (sách)."
                  }
                ],
                "exercises": [
                  {
                    "type": "type_sentence",
                    "prompt": "Dịch sang tiếng Trung: Cô ấy là bác sĩ.",
                    "accept": ["她是医生"],
                    "meaning": "Cô ấy là bác sĩ."
                  },
                  {
                    "type": "translate",
                    "direction": "vi_to_zh",
                    "prompt": "Đây là sách.",
                    "answer": "这是书。",
                    "options": ["这是书。", "这是人。", "他是书。", "这有书。"]
                  }
                ]
              }
            ],
            "test": {
              "timeLimit": 180,
              "passThreshold": 60,
              "questions": [
                {
                  "type": "fill_blank",
                  "sentence": "他___老师。",
                  "blank": "是",
                  "options": ["是", "很", "也", "不"]
                },
                {
                  "type": "sentence_order",
                  "words": ["是", "我", "学生"],
                  "answer": "我是学生"
                },
                {
                  "type": "translate",
                  "direction": "vi_to_zh",
                  "prompt": "Cô ấy là bác sĩ.",
                  "answer": "她是医生。",
                  "options": ["她是医生。", "他是老师。", "我是学生。", "你是医生。"]
                },
                {
                  "type": "type_sentence",
                  "prompt": "Dịch sang tiếng Trung: Tôi là người Trung Quốc.",
                  "accept": ["我是中国人"],
                  "meaning": "Tôi là người Trung Quốc."
                }
              ]
            }
          }
        },
